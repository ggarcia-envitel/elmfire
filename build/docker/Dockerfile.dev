# ELMFIRE_BASE can be overridden to pull from a registry instead of a local tag.
# Example (CI): --build-arg ELMFIRE_BASE=ghcr.io/org/elmfire:2025.1002
ARG ELMFIRE_VER=2025.1002
ARG ELMFIRE_BASE=elmfire:${ELMFIRE_VER}
FROM ${ELMFIRE_BASE}

RUN apt-get update -y && \
    apt-get install --no-install-recommends -y python3 python3-pip python3-venv && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/elmfire-venv && \
    /opt/elmfire-venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/elmfire-venv/bin/pip install --no-cache-dir \
        numpy pandas pyarrow rasterio pyproj pyyaml scipy

# riskmap-resolver: URI resolution for riskmap:// artifact paths.
# The resolver source is copied into the build context by 01-build-dev.sh
# from the sibling riskmap-resolver/ directory.
# Installing [all] includes s3fs, gcsfs, and adlfs so the image supports
# AWS S3, Google Cloud Storage, and Azure Blob Storage without rebuilding.
COPY riskmap-resolver/ /opt/riskmap-resolver/
RUN /opt/elmfire-venv/bin/pip install --no-cache-dir "/opt/riskmap-resolver[all]"

ENV PATH="/opt/elmfire-venv/bin:${PATH}"
